# PokeBot API - Environment Configuration

# Server Port
PORT=8080

# MySQL Database Configuration
DB_USER=pokebot_user
DB_PASSWORD=your_secure_password_here
DB_HOST=your-mysql-ip-or-hostname
DB_PORT=3306
DB_NAME=pokebot

# Optional: Gin Framework Mode
# Options: debug, release, test
GIN_MODE=release

# Optional: For local development with Docker Compose
# Uncomment these when using docker-compose.yml
# DB_USER=pokebot_user
# DB_PASSWORD=pokebot_password
# DB_HOST=mysql
# DB_PORT=3306
# DB_NAME=pokebot
